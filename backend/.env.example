# Shadow IT Discovery Bot - Environment Configuration Example
# Copy this file to .env and fill in your values

# Shodan API Key (optional - will use mock data if not provided)
# Get your key at: https://account.shodan.io
# Note: Free tier has limited credits; paid subscription recommended for production
SHODAN_API_KEY=

# Demo mode - set to "true" to always use mock data regardless of API key
DEMO_MODE=false

# Server configuration
HOST=0.0.0.0
PORT=8000

# CORS allowed origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:8000

# Network scanning options
# WARNING: Only scan networks you own or have permission to test
ENABLE_NETWORK_SCAN=true
SCAN_TIMEOUT=1.0
MAX_CONCURRENT_SCANS=5

# Rate limiting for Shodan API (requests per second)
SHODAN_RATE_LIMIT=1.0

# Scan retention (days before auto-deleting old scan results)
SCAN_RETENTION_DAYS=30

# API rate limiting (max requests per minute)
API_RATE_LIMIT=60
